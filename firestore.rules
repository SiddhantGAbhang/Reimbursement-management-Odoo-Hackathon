rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    function isDocOwner(data) {
      return isAuthenticated() && request.auth.uid == data.uid;
    }
    function isEmployeeOwner(data) {
      return isAuthenticated() && request.auth.uid == data.employeeId;
    }
    function isAdmin() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    function isManager() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'manager';
    }

    match /companies/{companyId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated(); // First login auto-creates
      allow update: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAdmin() || request.auth.uid == userId;
    }

    match /expenses/{expenseId} {
      allow read: if isAuthenticated(); // Managers/Admins need to see team expenses
      allow create: if isAuthenticated();
      allow update: if isAuthenticated(); // Approvers need to update
    }

    match /approvalRules/{ruleId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
